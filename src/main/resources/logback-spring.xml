<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Spring Boot 기본 콘솔 출력 패턴을 그대로 재사용 -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml" />
    <include resource="org/springframework/boot/logging/logback/console-appender.xml" />

    <!-- application.yml의 discord.webhook.error-url → Logback 컨텍스트로 브리지.
         값이 없으면(로컬/CI) DiscordLogbackAppender가 no-op으로 동작한다 (#188). -->
    <springProperty scope="context" name="discordWebhookUrl" source="discord.webhook.error-url" defaultValue="" />

    <appender name="DISCORD" class="com.membershipflow.common.logging.DiscordLogbackAppender">
        <webhookUrl>${discordWebhookUrl}</webhookUrl>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE" />
        <appender-ref ref="DISCORD" />
    </root>
</configuration>
